{
  "$schema": "https://vicinae.com/schemas/config.json",
  "providers": {
    "browser-extension": {
      "enabled": false
    },
    "calculator": {
      "entrypoints": {
        "history": {
          "alias": "="
        }
      }
    },
    "clipboard": {
      "preferences": {
        "encryption": false,
        "eraseOnStartup": true,
        "ignorePasswords": true,
        "monitoring": true
      }
    },
    "core": {
      "enabled": false
    },
    "developer": {
      "enabled": false
    },
    "files": {
      "entrypoints": {
        "search": {
          "alias": "file"
        }
      }
    },
    "font": {
      "enabled": false
    },
    "manage-shortcuts": {
      "enabled": false
    },
    "raycast-compat": {
      "enabled": false
    },
    "snippets": {
      "enabled": false
    },
    "system": {
      "entrypoints": {
        "run": {
          "alias": ">",
          "preferences": {
            "default-action": "run"
          }
        }
      }
    },
    "theme": {
      "enabled": false
    },
    "wm": {
      "entrypoints": {
        "switch-windows": {
          "alias": "<"
        }
      }
    }
  }
}
